// 定义串口1的中断回调函数
void onSerial1Receive() {
  // 当串口1触发中断时，执行此函数

  // 1. 获取当前接收到的数据长度
  int len = Serial1.available();

  if (len > 0) {
    // 2. 创建缓冲区读取数据 (复用之前的逻辑)
    uint8_t buffer[64]; // 假设一次不超过64字节

    // 防止溢出
    if (len > 64) len = 64;

    // 3. 批量读取
    Serial1.read(buffer, len);

    // 4. 回显：把读到的数据立刻发回去
    Serial1.write(buffer, len);
  }
}

void setup() {
  // 1. 初始化串口 0 (用于调试，连接到电脑USB)
  Serial.begin(115200);
  Serial.println("System Started. Listening on Serial1...");

  // 2. 初始化串口 1
  // 注意：ESP32 需要指定 RX 和 TX 引脚
  // 这里假设 RX=16, TX=17 (你可以根据实际接线修改)
  Serial1.begin(115200, SERIAL_8N1, 16, 17);

  // 3. 注册接收回调函数 (关键步骤)
  Serial1.onReceive(onSerial1Receive);
}

void loop() {
  // 主循环里不需要写任何关于串口1接收的代码
  // 程序会在这里做其他事，收到数据时会自动跳到 onSerial1Receive

  delay(1000);
  Serial.print("."); // 串口0打印心跳，证明程序没卡死
}
