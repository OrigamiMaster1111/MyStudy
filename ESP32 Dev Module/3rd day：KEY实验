#include "key.h"

void key_init(){
  pinMode(KEY_PIN, INPUT_PULLUP);/* 按键没有按下时，检测到的是高电平 */
}
#ifndef __KEY_H
#define __KEY_H

#include "Arduino.h"

#define KEY_PIN   0

#define KEY digitalRead(KEY_PIN)

void key_init(void);

#endif
