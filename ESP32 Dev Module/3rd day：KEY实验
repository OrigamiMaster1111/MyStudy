#include "key.h"
#include "LED.h"

void setup() {
  Serial.begin(115200);  // 开启串口打印
  led_init();
  key_init();
}

void loop() {
  Serial.print("GPIO0 电平：");
  Serial.println(KEY);  // 打印真实值


  /* #define KEY digitalRead(KEY_PIN) */
  if (KEY == 0){/*是否按下按钮*/
    delay(100);
    if (KEY == 0){/*软件消抖*/
      LED(0); /*LED亮*/
    }
  }
  else {
    LED(1);/*LED不亮*/
  }
}

#include "LED.h"

void led_init(){
  pinMode(LED_PIN, OUTPUT);
  digitalWrite(LED_PIN, HIGH);
}
#ifndef __LED_H
#define __LED_H

#include "Arduino.h"

#define LED_PIN 2
