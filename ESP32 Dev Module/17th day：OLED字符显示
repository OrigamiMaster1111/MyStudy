#include <Wire.h>
#include "SSD1306Wire.h"
SSD1306Wire display(0x3C, 18, 19, GEOMETRY_128_64, I2C_TWO, 800000);

void setup() {
  display.init();//初始化OLED
  display.flipScreenVertically();

  display.clear();


  // display.setPixelColor(10, 10, WHITE);
  display.setFont(ArialMT_Plain_16);
  display.drawString(0, 0, "I'm Metatron");

  display.setFont(ArialMT_Plain_24);
  display.drawString(0, 16, "Welcome!");

  display.drawLine(0, 50, 50, 50);

  display.display ();
}



void loop() {
}
