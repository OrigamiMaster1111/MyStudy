#ifndef __BEEP_H
#define __BEEP_H

#include "Arduino.h"

#define BEEP_PIN 18
#define BEEP(x)  digitalWrite(BEEP_PIN, x)
/*
  这段代码类似于这种函数形式
  void BEEP(int x) {
    digitalWrite(BEEP_PIN, x);
  }
*/
#define BEEP_TOGGLE() digitalWrite(BEEP_PIN, !digitalRead(BEEP_PIN))

void beep_init(void);

#endif
#include "key.h"
#include "LED.h"
#include "beep.h"
#include "timer.h"

int led_index = -1;
hw_timer_t *timer = NULL;
bool volatile count_flag = false;
uint8_t LED_PIN_ARR[5] {25, 33, 32, 35, 34};

void setup() {
  led_init();
  key_init();
  beep_init();
  timer_init();
}

void loop() {
  /* #define KEY digitalRead(KEY_PIN) */
  if (KEY() == 0){ /*是否按下按钮*/

    delay(100);
    
    if (KEY() == 0) { /*软件消抖*/
      led_index = -1;

      for (int i = 0; i < 5; ++i){
        LED(LED_PIN_ARR[i], HIGH);
      }
      count_flag = true;
    }
  }

  if (count_flag){
    BEEP(0);
    delay(100);
    BEEP(1);
    timer_enable();
    count_flag = false;
  }

  if (led_index == 5){
    // led_index = -1;
    timer_disable();
    BEEP_TOGGLE();
    delay(100);
    BEEP_TOGGLE();
  }
}

