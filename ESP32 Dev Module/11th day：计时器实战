#ifndef __LED_H
#define __LED_H

#include "Arduino.h"

uint8_t extern LED_PIN_ARR[5];

#define LED(LED_PIN, x)  digitalWrite(LED_PIN, x)
/*
  这段代码类似于这种函数形式
  void BEEP(int x) {
    digitalWrite(BEEP_PIN, x);
  }
*/
#define LED_TOGGLE(LED_PIN) digitalWrite(LED_PIN, !digitalRead(LED_PIN))

void led_init(void);

#endif
#include "timer.h"
#include "LED.h"
#include "esp32-hal-timer.h"

void timer_callback(){
  ++led_index;
  LED_TOGGLE(LED_PIN_ARR[led_index]);
}

void timer_init(){
  timer = timerBegin(1000000);
  timerAttachInterrupt(timer, timer_callback);
}

void timer_enable(){
  timerAlarm(timer, 1000000, true, 0);
}

void timer_disable(){
  // timerAlarmDisable()
  timerEnd(timer);
}
