uint32_t adc_vol = 0;

void setup(){
  Serial.begin(115200);
  pinMode(4, OUTPUT);
  digitalWrite(4, HIGH);
}

void loop(){
  adc_vol = analogReadMilliVolts(13);
  Serial.println(adc_vol);/*电压值（单位：毫伏）*/

  if (adc_vol > 2900){
    digitalWrite(4, LOW);
  }
  else {
    digitalWrite(4, HIGH);
  }
  delay(500);
}
