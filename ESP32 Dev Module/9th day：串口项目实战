#include "beep.h"
#include "LED.h"
#include <String>

int len = 0;
String serial_data;

void serial_callback(){
  if (Serial.available() > 0){

    len = Serial.available();

    // 数据接收
    for (int i = 0; i < len; ++i){
      serial_data += (char)Serial.read();
    }

    serial_data.trim();
    Serial.println(serial_data);

    // 数据解析
    if (serial_data.equals("LED_ON")){
      LED(1);
    }
    else if (serial_data.equals("LED_OFF")){
      LED(0);
    }
    else if (serial_data.equals("BEEP_ON")){
      BEEP(0);
    }
    else if (serial_data.equals("BEEP_OFF")){
      BEEP(1);
    }

    serial_data.clear();
  }
}

void setup(){
  Serial.begin(115200);

  beep_init();
  led_init();

  Serial.onReceive(serial_callback);
}

void loop(){

}
